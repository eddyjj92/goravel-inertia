import { Link, usePage } from '@inertiajs/react'
import type { ReactNode } from 'react'
import Logo from './components/Logo'

export default function Layout({ children }: { children: ReactNode }) {
  const page = usePage()
  const { flash = {}, timestamp } = page.props
  const isActive = (href: string, exact = false) =>
    exact ? page.url === href : page.url.startsWith(href)

  return (
    <div className="layout">
      <header className="topbar">
        <div className="bar">
          <Link href="/" className="brand" aria-label="Goravel Inertia — home">
            <Logo size={44} />
            <h3>Goravel Inertia</h3>
          </Link>

          <nav>
            <Link href="/" className={isActive('/', true) ? 'active' : ''}>Home</Link>
            <Link href="/feed" className={isActive('/feed') ? 'active' : ''}>Feed</Link>
            <Link href="/contact" className={isActive('/contact') ? 'active' : ''}>Contact</Link>
            <Link href="/about" className={isActive('/about') ? 'active' : ''}>About</Link>
            <a
              className="gh"
              href="https://github.com/eddyjj92/goravel-inertia"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Star goravel-inertia on GitHub"
              title="Star on GitHub"
            >
              <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
              </svg>
              <span>Star</span>
            </a>
          </nav>
        </div>
      </header>

      <main>
        <div className="container">
          {flash.success && <div className="flash flash-success">{flash.success}</div>}
          {flash.error && <div className="flash flash-error">{flash.error}</div>}
          {children}
        </div>
      </main>

      <footer>
        <div className="container foot">
          <span>Goravel + Inertia.js + React</span>
          <span className="muted">{timestamp}</span>
        </div>
      </footer>

      <style dangerouslySetInnerHTML={{ __html: styles }} />
    </div>
  )
}

// React has no single-file-component scoped styles, so the demo's CSS (layout +
// pages) lives here as one global stylesheet. Class names are unique per page.
const styles = `
:root {
  --go: #00add8;
  --inertia: #8b5cf6;
  --ink: #1f2937;
  --muted: #6b7280;
  --bg: #f6f8fc;
  --card: #ffffff;
  --border: #e6e9f0;
  --ring: rgba(0, 173, 216, 0.35);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
  background: var(--bg);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
}
a { color: inherit; }
.gi-logo { display: block; object-fit: contain; }
.layout { min-height: 100vh; display: flex; flex-direction: column; }
.container { width: 100%; max-width: 920px; margin: 0 auto; padding: 0 1.5rem; }

/* topbar */
.topbar {
  position: sticky; top: 0; z-index: 10;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
}
.bar {
  max-width: 920px; margin: 0 auto; padding: 0.7rem 1.5rem;
  display: flex; align-items: center; justify-content: space-between;
}
.brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
nav { display: flex; gap: 0.25rem; align-items: center; }
nav a {
  padding: 0.4rem 0.85rem; border-radius: 999px; text-decoration: none;
  font-size: 0.92rem; font-weight: 500; color: var(--muted);
  transition: background 0.15s, color 0.15s;
}
nav a:hover { color: var(--ink); background: #eef1f7; }
nav a.active { color: #fff; background: linear-gradient(135deg, var(--go), var(--inertia)); }
nav a.gh {
  display: inline-flex; align-items: center; gap: 0.35rem; margin-left: 0.4rem;
  color: var(--ink); background: #eef1f7; font-weight: 600;
}
nav a.gh:hover { color: #fff; background: var(--ink); }

/* main */
main { flex: 1; padding: 2.5rem 0 3rem; }

/* flash */
.flash { margin-bottom: 1.5rem; padding: 0.85rem 1.1rem; border-radius: 12px; font-size: 0.95rem; font-weight: 500; }
.flash-success { background: #e7f7ee; color: #11774b; border: 1px solid #b6e6cd; }
.flash-error { background: #fdecec; color: #b02a2a; border: 1px solid #f3c4c4; }

/* footer */
footer { border-top: 1px solid var(--border); padding: 1.25rem 0; font-size: 0.85rem; color: var(--muted); }
.foot { display: flex; justify-content: space-between; }
.muted { color: #9aa1ad; }

/* shared building blocks */
.card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 1.5rem; box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04); }
.btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: linear-gradient(135deg, var(--go), var(--inertia));
  color: #fff; border: none; border-radius: 10px; padding: 0.65rem 1.3rem;
  font: inherit; font-weight: 600; cursor: pointer;
  transition: opacity 0.15s, transform 0.05s;
}
.btn:hover { opacity: 0.92; }
.btn:active { transform: translateY(1px); }
.btn:disabled { opacity: 0.55; cursor: default; }
.page-title { font-size: 2rem; font-weight: 800; letter-spacing: -0.02em; }
.lead { color: var(--muted); margin-top: 0.4rem; }
.head { margin-bottom: 1.5rem; }

/* Home */
.home { display: flex; flex-direction: column; gap: 1.5rem; }
.hero { display: flex; align-items: center; gap: 1.5rem; background: linear-gradient(180deg, #ffffff, #fbfcff); }
.hero-body { display: flex; flex-direction: column; align-items: flex-start; }
.badge {
  display: inline-block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.04em;
  text-transform: uppercase; color: var(--inertia); background: #f1ecfe;
  padding: 0.3rem 0.6rem; border-radius: 999px;
}
.hero-title {
  margin-top: 0.9rem; font-size: 2.4rem; font-weight: 800; letter-spacing: -0.03em;
  background: linear-gradient(135deg, var(--go), var(--inertia));
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.stat {
  background: var(--card); border: 1px solid var(--border); border-radius: 14px;
  padding: 1.3rem; display: flex; flex-direction: column; gap: 0.35rem;
  min-height: 92px; justify-content: center;
}
.stat-value { font-size: 1.8rem; font-weight: 800; color: var(--go); }
.stat-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
.skeleton .bar {
  display: block; height: 1.8rem; width: 70%; border-radius: 6px;
  background: linear-gradient(90deg, #eef1f7 25%, #e3e8f0 37%, #eef1f7 63%);
  background-size: 400% 100%; animation: shimmer 1.3s ease infinite;
}
@keyframes shimmer { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }

/* Feed */
.feed { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
.feed-item { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem; }
.feed-item > div { display: flex; flex-direction: column; gap: 0.15rem; }
.dot {
  flex: none; width: 2.2rem; height: 2.2rem; display: grid; place-items: center;
  border-radius: 10px; font-size: 0.85rem; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--go), var(--inertia));
}
.body { color: var(--muted); font-size: 0.9rem; }
.actions { margin-top: 1.5rem; text-align: center; }

/* Contact */
.form { display: flex; flex-direction: column; gap: 1.1rem; }
.form label { display: flex; flex-direction: column; gap: 0.4rem; }
.label { font-size: 0.85rem; font-weight: 600; color: var(--ink); }
.form input, .form textarea {
  font: inherit; padding: 0.65rem 0.8rem; border: 1px solid var(--border);
  border-radius: 10px; background: #fff;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.form input:focus, .form textarea:focus { outline: none; border-color: var(--go); box-shadow: 0 0 0 3px var(--ring); }
.form label.invalid input, .form label.invalid textarea { border-color: #e57373; }
.error { color: #b02a2a; font-size: 0.8rem; }
.form .btn { align-self: flex-start; }

/* About */
.sub { font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; }
.stack { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.dep {
  display: flex; align-items: center; gap: 0.6rem; padding: 0.6rem 0.75rem;
  border: 1px solid var(--border); border-radius: 10px; text-decoration: none;
  color: var(--muted); font-size: 0.95rem; transition: border-color 0.15s, background 0.15s;
}
.dep:hover { border-color: var(--go); background: #f7fbfd; }
.dep-text { flex: 1; }
.ext { color: #b3b9c4; font-weight: 700; }
.dep:hover .ext { color: var(--go); }
.tag { font-size: 0.78rem; font-weight: 700; padding: 0.2rem 0.55rem; border-radius: 6px; color: #fff; }
.tag.go { background: #00add8; }
.tag.adapter { background: linear-gradient(135deg, #00add8, #8b5cf6); }
.tag.inertia { background: #8b5cf6; }
.tag.react { background: #61dafb; color: #1f2937; }
.tag.petaki { background: #1f2937; }
.tag.vite { background: #ffae00; color: #1f2937; }

@media (max-width: 640px) {
  .stats { grid-template-columns: 1fr; }
  .hero { flex-direction: column; text-align: center; }
  .hero-body { align-items: center; }
  .hero-title { font-size: 1.9rem; }
}
`
