  color: var(--inertia);
  font-weight: 700;
}
nav {
  display: flex;
  gap: 0.25rem;
}
nav a {
  padding: 0.4rem 0.85rem;
  border-radius: 999px;
  text-decoration: none;
  font-size: 0.92rem;
  font-weight: 500;
  color: var(--muted);
  transition: background 0.15s, color 0.15s;
}
