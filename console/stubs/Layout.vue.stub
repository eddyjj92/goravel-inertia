  border-radius: 12px;
  font-size: 0.95rem;
  font-weight: 500;
}
.flash-success {
  background: #e7f7ee;
  color: #11774b;
  border: 1px solid #b6e6cd;
}
.flash-error {
  background: #fdecec;
  color: #b02a2a;
  border: 1px solid #f3c4c4;
}
.flash-enter-active,
.flash-leave-active {
  transition: all 0.25s ease;
}
.flash-enter-from,
.flash-leave-to {
  opacity: 0;
  transform: translateY(-6px);
}

/* footer */
footer {
  border-top: 1px solid var(--border);
  padding: 1.25rem 0;
  font-size: 0.85rem;
  color: var(--muted);
}
.foot {
  display: flex;
  justify-content: space-between;
}
.muted {
  color: #9aa1ad;
}

/* shared building blocks for pages */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 1.5rem;
  box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
}
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: linear-gradient(135deg, var(--go), var(--inertia));
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 0.65rem 1.3rem;
  font: inherit;
  font-weight: 600;
