<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title inertia>Goravel Inertia</title>
    {{ if .ssr }}{{ raw .ssr.Head }}{{ end }}
    {{ vite "resources/js/app.ts" }}
</head>
<body>
